# Set this to a Formspree, Web3Forms, EmailJS proxy, or serverless endpoint before launch.
VITE_FORM_ENDPOINT=

# CMS OAuth — server-side Vercel environment variables only. Never use the VITE_ prefix here.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
CMS_OAUTH_CALLBACK_URL=https://phuongphuong.vercel.app/api/callback
CMS_ALLOWED_ORIGIN=https://phuongphuong.vercel.app
CMS_STATE_SECRET=
CMS_GITHUB_SCOPE=public_repo
